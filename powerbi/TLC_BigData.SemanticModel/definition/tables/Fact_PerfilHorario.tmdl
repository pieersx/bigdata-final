		lineageTag: b1905546-f140-46c7-ab65-410c15e4e2cc
		summarizeBy: none
		sourceColumn: trip_count

	column total_revenue
		dataType: double
		formatString: #,0.00
		lineageTag: 5b89b3d6-bc53-4746-992f-c52f09e6e6d1
