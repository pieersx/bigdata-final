table Fact_PerfilHorario
	lineageTag: 152300af-a41e-4bec-ba40-ddf53355e076

	measure 'D2 Viajes Totales' = SUM(Fact_PerfilHorario[trip_count])
		formatString: #,0
		displayFolder: Medidas
		lineageTag: e6fb2d12-e86d-4e69-8553-6942c45799e1

	measure 'D2 Duracion Promedio Ponderada' = DIVIDE(SUM(Fact_PerfilHorario[duration_minutes]), [D2 Viajes Totales])
		formatString: 0.00 "min"
		displayFolder: Medidas
		lineageTag: 718d10ad-c018-41c8-bcb4-65835da100cd

	measure 'D2 Ingresos Totales' = SUM(Fact_PerfilHorario[total_revenue])
		formatString: $#,0.00
		displayFolder: Medidas
		lineageTag: fe868cff-fd2b-4dfb-be93-6995aafacdf1

	column pickup_date
		dataType: dateTime
		formatString: Short Date
		lineageTag: 8896e60b-3d4a-4c98-b94b-06940043a586
		summarizeBy: none
		sourceColumn: pickup_date

		annotation UnderlyingDateTimeDataType = Date

	column pickup_month
