table Fact_FactoresPropina
	lineageTag: 11335b8b-d777-49ac-8868-16564274ec98

	measure 'D6 Tasa Propina Ponderada' = DIVIDE(SUM(Fact_FactoresPropina[Ingresos por propinas]), SUM(Fact_FactoresPropina[Ingresos por tarifa]))
		formatString: 0.00%
		displayFolder: Medidas
		lineageTag: 354de1df-9b95-4e15-978f-f01c9bf03c52

	measure 'D6 Viajes con Propina %' = DIVIDE(SUM(Fact_FactoresPropina[Viajes con propina]), SUM(Fact_FactoresPropina[Cantidad de viajes]))
		formatString: 0.00%
		displayFolder: Medidas
		lineageTag: e960a10a-b091-4124-8843-b2144d230631

	measure 'D6 Viajes Analizados' = SUM(Fact_FactoresPropina[Cantidad de viajes])
		formatString: #,0
		displayFolder: Medidas
		lineageTag: 4bdae669-816a-448e-9b35-841fec71dfd9

