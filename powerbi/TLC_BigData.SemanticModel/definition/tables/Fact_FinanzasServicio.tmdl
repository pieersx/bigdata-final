table Fact_FinanzasServicio
	lineageTag: c3a328b8-14f9-40ae-8ead-bf664c10b453

	measure 'D3 Ingresos Totales' = SUM(Fact_FinanzasServicio[total_revenue])
		formatString: $#,0.00
		displayFolder: Medidas
		lineageTag: dcf47ae3-e43e-4849-8f96-4dc5715de543

	measure 'D3 Propinas Totales' = SUM(Fact_FinanzasServicio[tip_revenue])
		formatString: $#,0.00
		displayFolder: Medidas
		lineageTag: 864d4997-7876-4848-a7bd-6383e7eb5f41

	measure 'D3 Tasa Propina Ponderada' = DIVIDE(SUM(Fact_FinanzasServicio[tip_revenue]), SUM(Fact_FinanzasServicio[fare_revenue]))
		formatString: 0.00%
		displayFolder: Medidas
		lineageTag: ead3bd29-9679-4135-a49c-31ce65d6e3ab

	measure 'D3 Viajes con Propina %' = DIVIDE(SUM(Fact_FinanzasServicio[tipped_trips]), SUM(Fact_FinanzasServicio[trip_count]))
		formatString: 0.00%
		displayFolder: Medidas
		lineageTag: 4fc0bf44-0d00-4a79-bbd9-c4547262e5a6

	column pickup_month
