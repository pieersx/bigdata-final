table Fact_MetricasPronostico

	measure 'D7 Error WMAPE' = DIVIDE(CALCULATE(MAX(Fact_MetricasPronostico[Valor de la métrica]), Fact_MetricasPronostico[Nombre de la métrica] = "wmape_percent"), 100)
		formatString: 0.00%
		displayFolder: Medidas

	measure 'D7 Error RMSE' = CALCULATE(MAX(Fact_MetricasPronostico[Valor de la métrica]), Fact_MetricasPronostico[Nombre de la métrica] = "rmse")
		formatString: #,0.00
		displayFolder: Medidas

	measure 'D7 Coeficiente R²' = CALCULATE(MAX(Fact_MetricasPronostico[Valor de la métrica]), Fact_MetricasPronostico[Nombre de la métrica] = "r2")
		formatString: 0.0000
		displayFolder: Medidas

	column 'Nombre del modelo'
		dataType: string
		summarizeBy: none
		sourceColumn: model_name

	column 'Nombre de la métrica'
		dataType: string
		summarizeBy: none
		sourceColumn: metric_name

	column 'Valor de la métrica'
		dataType: double
		formatString: #,0.00
		summarizeBy: none
		sourceColumn: metric_value

	column 'Detalle de la métrica'
		dataType: string
		summarizeBy: none
		sourceColumn: metric_text

	column 'Fecha de generación UTC'
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: generated_at_utc

	partition Fact_MetricasPronostico = m
		mode: import
		source =
				let
				    Origen = Folder.Files("C:/Users/Pieers/dev/bigdata-final/data/gold/model_timeseries_metrics"),
				    Parquet = Table.SelectRows(Origen, each [Extension] = ".parquet"),
				    ConDatos = Table.AddColumn(Parquet, "Data", each let p=Text.Replace([Folder Path], "\\", "/"), y=try Number.FromText(Text.BeforeDelimiter(Text.AfterDelimiter(p, "pickup_year="), "/")) otherwise null, m=try Number.FromText(Text.BeforeDelimiter(Text.AfterDelimiter(p, "pickup_month="), "/")) otherwise null, t=Parquet.Document([Content]) in t),
				    Combinado = Table.Combine(ConDatos[Data])
				in
				    Combinado

	annotation PBI_ResultType = Table
